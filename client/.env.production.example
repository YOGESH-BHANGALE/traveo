# Traveo Frontend - Production Environment Variables
# Copy this file and fill in your production values

# Node Environment
NODE_ENV=production

# Backend API URL (your Render backend URL)
NEXT_PUBLIC_API_URL=https://traveo-backend.onrender.com

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google OAuth Client ID (same as backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Razorpay Key ID (public key - safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_id

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
