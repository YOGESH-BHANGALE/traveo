# Server Configuration
NODE_ENV=development
PORT=5000

# Database - Get from MongoDB Atlas
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/traveo?retryWrites=true&w=majority

# JWT Configuration - Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# Google OAuth - Get from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Google Maps - Get from Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Frontend URL
CLIENT_URL=http://localhost:3000

# AI Chatbot Configuration
AI_PROVIDER=openai
# Choose: 'openai' for ChatGPT or 'claude' for Claude AI

# OpenAI API Key (for ChatGPT)
OPENAI_API_KEY=your_openai_api_key_here

# Claude API Key (for Claude AI)
CLAUDE_API_KEY=your_claude_api_key_here

# Razorpay — Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# VAPID Keys for Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@traveo.com
